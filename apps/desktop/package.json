{
  "name": "resume-matcher-desktop",
  "version": "1.1.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "postbuild": "node dist/scripts/copyUiAssets.js",
    "dev": "npm run build && electron dist/main.js",
    "start": "npm run build && electron dist/main.js",
    "bundle:runtime": "npm --prefix ../.. run desktop:bundle-runtime",
    "pack:win": "electron-builder --win nsis --dir --config electron-builder.json",
    "dist:win": "electron-builder --win nsis --config electron-builder.json",
    "release:win": "npm run build && npm run bundle:runtime && npm run dist:win",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^25.2.1",
    "electron": "^35.0.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
  }
}
